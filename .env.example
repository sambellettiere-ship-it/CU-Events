# Database (SQLite file path)
DATABASE_URL=./cu-events.db

# Auth (generate a secure random string)
JWT_SECRET=your-random-secret-here-change-this-in-production

# Stripe (get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Geocoding (Nominatim - free, no API key needed)
NOMINATIM_USER_AGENT=cu-events/1.0 (your-email@example.com)

# Admin seed credentials
ADMIN_EMAIL=admin@cu-events.com
ADMIN_PASSWORD=admin123
